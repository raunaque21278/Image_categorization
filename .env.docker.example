# Copy to .env on your DigitalOcean Droplet

JWT_SECRET=your-long-random-secret-here
HF_API_KEY=hf_your_huggingface_token

GOOGLE_VISION_KEY_PATH=./worker/config/google-vision.json

# Replace with your Droplet public IP or domain
# Example: http://157.230.123.45  or  http://yourdomain.com
CORS_ORIGIN=http://YOUR_DROPLET_IP
