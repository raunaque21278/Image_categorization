# Copy to .env in project root before: docker compose up --build

JWT_SECRET=your-secure-jwt-secret
HF_API_KEY=your-huggingface-token

# Path to your Google Cloud Vision service account JSON (local machine path)
GOOGLE_VISION_KEY_PATH=./worker/config/google-vision.json

# Frontend CORS origin (browser URL)
CORS_ORIGIN=http://localhost:3000
