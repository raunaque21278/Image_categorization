# Copy to .env in project root before running:
#   cp .env.docker.example .env
#   docker compose up --build

JWT_SECRET=your-secure-jwt-secret
HF_API_KEY=your-huggingface-token

# Path to Google Cloud Vision service account JSON (on your machine)
GOOGLE_VISION_KEY_PATH=./worker/config/google-vision.json

# Browser URL when using Docker frontend on port 3000
CORS_ORIGIN=http://localhost:3000
