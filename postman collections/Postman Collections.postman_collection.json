                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/retry/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "retry", "{{jobId}}"]
            },
            "description": "Re-queue a failed job for processing. Requires `retryRoutes` to be mounted in `server.js`."
          },
          "response": []
        }
